<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1"/>
        <title>{% block title %}Sap-Lu application{% endblock %}</title>

        {% block stylesheets %}        
            {{ encore_entry_link_tags('app') }}
        {% endblock %}
        
        <link rel="icon" type="image/x-icon" href="{{ asset('favicon.ico') }}" />
    </head>
    <body class="d-flex flex-column h-100">

        {% block header %}

            <nav class="navbar navbar-expand-lg">
                <div class="d-flex justify-content-center">
                    <img src="img/saplu.jpg" id="iconoSaplu">
                    <ul class="navbar-nav">
                        <li class="nav-item active">
                            <a class="nav-link" href="{{path('home')}}">Home</a>
                        </li>
                        {% if app.user %}
                            <li class="nav-item">
                                <a class="nav-link" href="{{path('app_register_work')}}">Registrar trabajo</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="{{path('app_query_user')}}">Consultar usuario</a>
                            </li>
                            {% if app.user.role == 'Administrador' %}
                                <li class="nav-item active">
                                    <a class="nav-link" href="{{path('app_register_user')}}">Registrar trabajador</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="{{path('app_register_client')}}">Registrar usuario</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="{{path('app_job_history')}}">Mostrar histórico</a>
                                </li>
                        {% endif %}
                            <li class="nav-item active">
                                <a class="nav-link" href="{{path('app_logout')}}">Cerrar sesión</a>
                            </li>
                        {% else %}
                            <li class="nav-item active">
                                <a class="nav-link" href="{{path('app_login')}}">Login</a>
                            </li>
                        {% endif %}
                    </ul>
                </div>
            </nav>

        {% endblock %}

        {% block body %}               
            <div id="page-content-wrapper">
                {% block main %}{% endblock %}
            </div>                
        {% endblock %}

        {% block footer %}
        {% endblock %}

        {% block javascripts %}
            {{ encore_entry_script_tags('app') }}
        {% endblock %}
    </body>
</html>
