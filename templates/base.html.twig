<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1"/>
        <title>{% block title %}Sap-Lu application{% endblock %}</title>

        {% block stylesheets %}        
            {{ encore_entry_link_tags('app') }}
        {% endblock %}
        
        <link rel="icon" type="image/x-icon" href="{{ asset('favicon.ico') }}" />
        <link rel="stylesheet" href="{{ asset('stylesForProd.css') }}">
    </head>
    <body class="d-flex flex-column h-100">

        {% block header %}

            {{ include('navBar.html.twig') }}

        {% endblock %}

        {% block body %}      

            <div id="page-content-wrapper">
                {% block main %}{% endblock %}
            </div>

        {% endblock %}

        {% block footer %}
        {% endblock %}

        {% block javascripts %}

            {{ encore_entry_script_tags('app') }}
            
        {% endblock %}
    </body>
</html>
