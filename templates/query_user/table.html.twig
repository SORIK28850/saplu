{% extends 'base.html.twig' %}

{% block title %}Sap-Lu application{% endblock %}

{% block body %}

    <table class="table table-bordered mt-3" id="tableUserInfo">
        <thead>
            <tr>
            <th scope="col-2">Nombre</th>
            <th scope="col-2">Teléfono</th>
            <th scope="col-2">Dirección</th>
            <th scope="col-2">Cuidados</th>
            </tr>
        </thead>
        <tbody>
            <tr>
            <td>{{data.name}}</td>
            <td>{{data.phone}}</td>
            <td>{{data.address}}</td>
            <td>{{data.cares}}</td>
            </tr>
        </tbody>
    </table>

{% endblock %}
